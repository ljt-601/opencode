            "context": 262144,
            "output": 65536
          }
        },
        "xiaomi/mimo-v2-pro": {
          "name": "小米 MiMo-V2-Pro",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "xiaomi/mimo-v2-omni": {
          "name": "小米 MiMo-V2-Omni",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "stepfun/step-3.5-flash:free": {
          "name": "StepFun 3.5 Flash (Free)",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "nvidia/nemotron-3-super-120b-a12b:free": {
          "name": "NVIDIA Nemotron 3 Super (Free)",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "z-ai/glm-4.5-air:free": {
          "name": "GLM 4.5 Air (Free)",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "minimax/minimax-m2.5:free": {
          "name": "MiniMax M2.5 (Free)",
          "limit": {
            "context": 196608,
            "output": 65536
          }
        },
        "qwen/qwen3-coder:free": {
          "name": "Qwen3 Coder 480B (Free)",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        },
        "qwen/qwen3-next-80b-a3b-instruct:free": {
          "name": "Qwen3 Next 80B (Free)",
          "limit": {
            "context": 262144,
