{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "snapshot": false,
  "model": "anthropic/claude-sonnet-4-5",
  "permission": {
    "bash": "ask",
    "edit": "ask"
  },
  "plugin": [
    "opencode-antigravity-auth@latest",
    "oh-my-openagent@latest"
  ],
  "provider": {
    "google": {
      "models": {
        "claude-opus-4-5-thinking": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Claude Opus 4.5 Thinking",
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "claude-sonnet-4-5": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Claude Sonnet 4.5"
        },
        "claude-sonnet-4-5-thinking": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Claude Sonnet 4.5 Thinking",
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "gemini-2.5-flash": {
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 2.5 Flash"
        },
        "gemini-2.5-pro": {
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 2.5 Pro"
        },
        "gemini-3-flash": {
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 3 Flash",
          "variants": {
            "high": {
              "thinkingLevel": "high"
            },
            "low": {
              "thinkingLevel": "low"
            },
            "medium": {
              "thinkingLevel": "medium"
            },
            "minimal": {
              "thinkingLevel": "minimal"
            }
          }
        },
        "gemini-3-pro": {
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Gemini 3 Pro",
          "variants": {
            "high": {
              "thinkingLevel": "high"
            },
            "low": {
              "thinkingLevel": "low"
            }
          }
        }
      }
    },
    "nvidia": {
      "models": {
        "minimaxai/minimax-m2.1": {
          "limit": {
            "context": 196608,
            "output": 128000
          },
          "name": "nvidia-m2.1"
        },
        "z-ai/glm4.7": {
          "limit": {
            "context": 204800,
            "output": 131072
          },
          "name": "nvidia-glm4.7"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "<YOUR_NVIDIA_API_KEY>",
        "baseURL": "https://integrate.api.nvidia.com/v1"
      }
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimaxi.com/anthropic/v1",
        "apiKey": "<YOUR_MINIMAX_API_KEY>"
      },
      "models": {
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5"
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "<YOUR_OPENROUTER_API_KEY>",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "openrouter/free": {
          "name": "OpenRouter Free Router",
